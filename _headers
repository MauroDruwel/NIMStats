/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://static.cloudflareinsights.com 'unsafe-inline'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'

/top
  Content-Type: application/json
  Access-Control-Allow-Origin: *
/top/model
  Content-Type: text/plain
  Access-Control-Allow-Origin: *
/top/speed
  Content-Type: application/json
  Access-Control-Allow-Origin: *
/top/speed/model
  Content-Type: text/plain
  Access-Control-Allow-Origin: *
/top/intelligence
  Content-Type: application/json
  Access-Control-Allow-Origin: *
/top/intelligence/model
  Content-Type: text/plain
  Access-Control-Allow-Origin: *
